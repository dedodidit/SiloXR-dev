SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=api.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com,https://yourdomain.com
DB_BACKEND=postgres
POSTGRES_DB=siloxr
POSTGRES_USER=siloxr
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=require
FRONTEND_BASE_URL=https://yourdomain.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=peopleofsiloxr@gmail.com
EMAIL_HOST_PASSWORD=replace-with-gmail-app-password
DEFAULT_FROM_EMAIL=SiloXR <peopleofsiloxr@gmail.com>
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_BOT_USERNAME=replace-with-bot-username
TELEGRAM_WEBHOOK_SECRET=replace-with-webhook-secret
PAYSTACK_PUBLIC_KEY=pk_live_replace_me
PAYSTACK_SECRET_KEY=sk_live_replace_me
PAYSTACK_CALLBACK_URL=https://yourdomain.com/billing/upgrade
PAYSTACK_PRO_MONTHLY_NAIRA=15000
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
USE_X_FORWARDED_HOST=true
